<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <!-- <meta name="viewport" content="width=device-width, initial-scale=1.0"> -->
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{{ title | default: site.title }}</title>
    <link rel="stylesheet" href="/style/style.css">
    <!-- Icons -->
    <link rel="icon" type="image/png" href="/img/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="shortcut icon" href="/img/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Softwave" />
    <link rel="manifest" href="/img/site.webmanifest" />



    <!-- Include JQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" type="text/javascript"></script>
    <script src="/main.js" type="text/javascript"></script>
    {% assign pageTitle = title | default: site.title %}
    {% assign pageDescription = description | default: site.description %}
    {% assign pageImage = image | default: site.image %}
    {% assign pagePath = page.url | default: '/' %}

    {% if pageImage contains '://' %}
      {% assign pageImageUrl = pageImage %}
    {% else %}
      {% assign pageImagePath = pageImage | remove_first: '/' %}
      {% assign pageImageUrl = site.url | append: pageImagePath %}
    {% endif %}

    {% if pagePath contains '://' %}
      {% assign pageUrl = pagePath %}
    {% else %}
      {% assign pagePathNormalized = pagePath | remove_first: '/' %}
      {% assign pageUrl = site.url | append: pagePathNormalized %}
    {% endif %}

    <meta name="description" content="{{ pageDescription }}">
    <link rel="canonical" href="{{ pageUrl }}">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:site_name" content="{{ site.title }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:image" content="{{ pageImageUrl }}">
    <meta property="og:image:alt" content="{{ pageTitle }}">
    <meta property="og:url" content="{{ pageUrl }}">
    <meta property="og:type" content="website">

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ pageTitle }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ pageImageUrl }}">
</head>
